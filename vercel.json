{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["gru1"],
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "src/app/api/**/*": {
      "maxDuration": 60
    },
    "src/app/api/cron/reconcile-sheets/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/noticias",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/reconcile-sheets?autofix=1",
      "schedule": "0 3 * * 1-5"
    },
    {
      "path": "/api/cron/triagem-sync-planilha",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}
